# K-Life Demo Configuration

# Heartbeat interval in milliseconds (default: 30000 = 30s)
HEARTBEAT_INTERVAL_MS=30000

# Monitor timeout before triggering resurrection (default: 90000 = 90s)
TIMEOUT_MS=90000

# Monitor check interval (default: 5000 = 5s)
CHECK_INTERVAL_MS=5000

# For accelerated demo (3s heartbeats, 15s timeout):
# HEARTBEAT_INTERVAL_MS=3000
# TIMEOUT_MS=15000
# CHECK_INTERVAL_MS=2000

# Max heartbeats before agent "crashes" (0 = infinite)
MAX_BEATS=0
